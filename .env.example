ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/isle_be_there
ENABLE_BACKGROUND_JOBS=false
FRONTEND_URL=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# Optional in local development because the app falls back to local-safe defaults.
JWT_SECRET_KEY=
FORGET_PWD_SECRET_KEY=

# Optional integrations. Leave blank for a minimal local demo.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads
